# ============================================================
# ESP Platform - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DB_USER=espplatform
DB_PASS=changeme_strong_password
DB_NAME=espplatform

# --- Backend Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- MQTT ---
MQTT_BROKER=mosquitto
MQTT_PORT=1883
# Leave empty for anonymous (MVP). Set for production.
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- File Storage ---
OTA_STORAGE_PATH=/app/firmware_storage
PIO_WORKSPACE=/app/pio_workspace

# --- Dashboard (injected at build time by Vite) ---
VITE_API_URL=http://localhost/api
VITE_MQTT_WS_URL=ws://localhost/mqtt

# --- Compiler ---
# Max concurrent PlatformIO builds (increase carefully - each uses ~500MB RAM)
MAX_CONCURRENT_BUILDS=1

# --- OTA ---
# Base URL the ESP32 will use to download firmware (must be reachable from device)
OTA_DOWNLOAD_BASE_URL=http://your-vps-ip/api/ota/download
